# MySQL холболт — schema.sql / migration-уудыг ЯГ ЭНЭ database дээр ажиллуулсан нэртэй тааруулна
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=0000
MYSQL_DATABASE=zeel_platform
# Aiven / cloud MySQL (Vercel deploy): заавал 1
# MYSQL_SSL=1
# MYSQL_SSL_CA=-----BEGIN CERTIFICATE-----... (Aiven CA PEM — шаардвал)

# Prisma (`prisma generate`, `job_posts` унших) — заавал биш; байхгүй бол MYSQL_*-аас автоматаар угсарна.
# DATABASE_URL=mysql://root:0000@127.0.0.1:3306/zeel_platform

# Google Gemini — AI Job Match (`/ai-job-match`, `POST /api/ai-match`)
# Түлхүүр авах алхам:
#   1) Хөтчөөр нээнэ: https://aistudio.google.com/apikey
#   2) Google account-оор нэвтэрнэ (шинээр үүсгэж болно).
#   3) "Create API key" → төсөл сонгоно эсвэл "Create API key in new project".
#   4) Хуулагдсан түлхүүрийг доор нэг мөрөөр наана (хашилтгүй).
#   5) Зөвхөн `.env.local` файлд бичнэ (Git-д битгий commit хийгээрэй).
# GEMINI_API_KEY=AIza...бүхэл_түлхүүр
# Сонголттой: боломжит загвар (суурь `gemini-1.5-flash` бүү ашигла — ихэвчлэн 404). Жишээ:
# GEMINI_MODEL=gemini-2.0-flash
# эсвэл: gemini-2.5-flash, gemini-1.5-flash-latest
# Алдаа "API key not valid" гэвэл түлхүүрийг дахин үүсгэж, хуулбарыг шалгана уу.

# Ажлын зар: ихэвчлэн хоосон эсвэл MYSQL_DATABASE-тай ижил. Өөр нэртэй DB руу заавал
# (хоосон job_posts) заавал бол зөвхөн тэнд уншина — UI дээр мөр харагдахгүй.
# JOBS_DATABASE=zeel_platform

# —— Google OAuth (нэвтрэх) ——
# Google Cloud Console → Credentials → OAuth client ID
# Authorised JavaScript origins: http://localhost:3000
# Authorised redirect URIs: http://localhost:3000/api/auth/google/callback
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# Next.js-ийн бодит хаяг (Stripe буцах URL). Grafana :3000 дээр ажиллавал 3001 ашиглана:
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Session хугацаа (өдрөөр)
SESSION_DAYS=7

# Site URL (SEO, и-мэйл доторх линк — продакшн дээр заавал https://таны-домэйн)
# NEXT_PUBLIC_SITE_URL=https://cwork.example

# Node environment
NODE_ENV=development

# Migration-ууд: npm run db:migrate (013 banner/logo, 014 leads, 015 escrow)

# Demo one-click login (default: development=true, production=false)
# DEMO_LOGIN_ENABLED=1

# И-мэйл (продакшн: нууц үг сэргээх, баталгаажуулалт — SMTPгүй бол и-мэйл явахгүй)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@cwork.example
# SMTPгүй үед Vercel дээр холбоосыг хуудсан дээр харуулах (зөвхөн туршилт/хөгжүүлэлт)
# PASSWORD_RESET_EXPOSE_LINK=1

# Бүх static + uploads нэг volume дээр байлгах (сонголттой)
# CW_PUBLIC_ROOT=/app/public

# —— Stripe (profile → Upgrade, Checkout + webhook) ——
# ЭНД бодит түлхүүр БИЧИХГҮЙ — зөвхөн .env.local (Git-д орохгүй) эсвэл scripts/dev-stripe-env.ps1.
# Алхам: төслийн үндсэн хавтас дээр .env.local файл үүсгээд доорх мөрүүдийг ХАШИГГҮЙ болгож хуулж,
# = баруун талд өөрийн Stripe Dashboard-оос авсан утгыг НЭГ мөрөөр бичнэ.
#
# STRIPE_SECRET_KEY=sk_test_...бүхэл_түлхүүр_нэг_мөр...
# STRIPE_WEBHOOK_SECRET=whsec_...stripe_listen_эсвэл_dashboard_webhook...
# Webhook events: checkout.session.completed, customer.subscription.created (сонголт), customer.subscription.updated (сонголт)
# Canonical tier: PREMIUM → STRIPE_PRICE_ID_PREMIUM (эсвэл legacy STRIPE_PRICE_ID_PRO)
# STANDARD → STRIPE_PRICE_ID_STANDARD (эсвэл legacy STRIPE_PRICE_ID_BUSINESS)
# STRIPE_PRICE_ID_PREMIUM=price_...
# STRIPE_PRICE_ID_STANDARD=price_...
# STRIPE_PRICE_ID_PRO=price_...subscription_price_pro...
# STRIPE_PRICE_ID_BUSINESS=price_...subscription_price_business...
# STRIPE_DNS_IPV4FIRST=1
# Next.js-ийн бодит хаяг (Stripe буцах URL). Grafana :3000 дээр ажиллавал 3001 ашиглана:
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# —— S3 / CDN upload (banner, logo, avatar) ——
# Локал: public/uploads/ диск. Vercel deploy: S3 эсвэл Cloudflare R2 ЗААВАЛ (локал диск ажиллахгүй).
# S3_BUCKET=cwork-uploads
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# S3_ENDPOINT=  (R2/MinIO бол endpoint)
# S3_FORCE_PATH_STYLE=1
# S3_FALLBACK_LOCAL=1

# —— QPay (escrow төлбөр) ——
# QPAY_USERNAME=
# QPAY_PASSWORD=
# QPAY_INVOICE_CODE=
# QPAY_API_BASE=https://merchant.qpay.mn/v2
# QPAY_CALLBACK_URL=https://your-domain/api/payments/qpay/callback

# Чат real-time: sse (default). WebSocket server Next.js-д байхгүй.
# REALTIME_PROVIDER=sse
# PUSHER_APP_ID=  (удаахгүй)

# Prod шалгалт: npm run prod:check (dev server ажиллаж байхад)
